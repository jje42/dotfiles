// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  // "buffer_font_family": "BlexMono Nerd Font Mono",
  "agent_servers": {
    "codex-acp": {
      "type": "registry"
    }
  },
  "cli_default_open_behavior": "existing_window",
  "icon_theme": {
    "mode": "light",
    "light": "Zed (Default)",
    "dark": "Zed (Default)"
  },
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "buffer_font_family": "ZedMono Nerd Font",
  "edit_predictions": {
    "provider": "zed",
  },
  "agent": {
    "dock": "right",
    "tool_permissions": {
      "default": "allow",
    },
    "model_parameters": [],
    "default_profile": "ask",
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "provider": "copilot_chat",
      "model": "claude-opus-4.6",
    },
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "vim_mode": true,
  "base_keymap": "VSCode",
  "ui_font_size": 20,
  "buffer_font_size": 20,
  "theme": {
    "mode": "dark",
    "light": "Ayu Mirage",
    "dark": "Ayu Dark",
  },
  "cursor_blink": false,
  // "features": {
  //   "copilot": true,
  // },
  "inlay_hints": {
    "enabled": true,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true,
  },
  // "soft_wrap": "bounded",
  "preferred_line_length": 80,
  "show_wrap_guides": true,
  // "editor": {
  //   "format_on_save": "on",
  // },
  // "languages": {
  //   "Python": {
  //     "language_servers": ["basedpyright", "ruff-lsp", "pyright"],
  //     "formatter": {
  //       "external": {
  //         "command": "ruff",
  //         "arguments": ["format", "--stdin-filename", "{buffer_path}", "-"],
  //       },
  //     },
  //   },
  // },
  "diagnostics": {
    "include_warnings": true,
    "inline": {
      "enabled": true,
    },
  },
}
